{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"formatter": {
		"enabled": false
	},
	"linter": {
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "warn"
			},
			"a11y": {
				"recommended": true
			},
			"performance": {
				"recommended": true
			}
		}
	},
	"files": {
		"includes": ["src/**", "e2e/**", "*.ts", "*.tsx", "*.js", "*.mjs"]
	}
}
