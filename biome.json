{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"formatter": {
		"enabled": false
	},
	"linter": {
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noConsole": "warn"
			},
			"a11y": {
				"preset": "recommended"
			},
			"performance": {
				"preset": "recommended"
			}
		}
	},
	"files": {
		"includes": ["src/**", "e2e/**", "*.ts", "*.tsx", "*.js", "*.mjs"]
	}
}
